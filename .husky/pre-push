#!/bin/sh
# metaswarm pre-push hook
# Enforces quality gates before pushing to remote.

echo "Running metaswarm pre-push quality gates..."

# 1. Lint
npm run lint || { echo "Linting failed. Push aborted."; exit 1; }

# 2. Type Check
npm run typecheck || { echo "Type checking failed. Push aborted."; exit 1; }

# 3. Tests with Coverage
npm run test -- --coverage || { echo "Tests or coverage threshold failed. Push aborted."; exit 1; }

echo "All quality gates passed. Proceeding with push."
exit 0
