{
  "nodes": [
    {
      "id": "project:gemini-discord",
      "type": "Project",
      "name": "gemini-discord",
      "properties": {
        "version": "0.1.0",
        "description": "Always-on Discord gateway for Gemini CLI. Bidirectional chat, conversation memory, streaming responses.",
        "license": "MIT",
        "type": "module"
      }
    },
    {
      "id": "component:discord-daemon",
      "type": "Component",
      "name": "Discord Daemon",
      "properties": {
        "responsibility": "Owns Discord client, queue, persistent memory, and localhost control API.",
        "entrypoint": "src/daemon.ts",
        "port": 18790
      }
    },
    {
      "id": "component:mcp-server",
      "type": "Component",
      "name": "MCP Server",
      "properties": {
        "responsibility": "Registers tools and can auto-start the daemon.",
        "entrypoint": "src/server.ts"
      }
    },
    {
      "id": "library:discord.js",
      "type": "Library",
      "name": "discord.js",
      "properties": {
        "version": "^14.18.0"
      }
    },
    {
      "id": "library:genai",
      "type": "Library",
      "name": "@google/genai",
      "properties": {
        "version": "^1.50.1"
      }
    },
    {
      "id": "library:mcp-sdk",
      "type": "Library",
      "name": "@modelcontextprotocol/sdk",
      "properties": {
        "version": "^1.12.0"
      }
    },
    {
      "id": "tool:discord_status",
      "type": "Tool",
      "name": "discord_status",
      "properties": {
        "description": "Shows daemon health, memory scope, and allowlist/routing state."
      }
    },
    {
      "id": "tool:discord_send",
      "type": "Tool",
      "name": "discord_send",
      "properties": {
        "description": "Sends a message to an allowed guild channel or enabled DM target."
      }
    },
    {
      "id": "tool:discord_reply",
      "type": "Tool",
      "name": "discord_reply",
      "properties": {
        "description": "Replies to a specific message ID in Discord."
      }
    },
    {
      "id": "tool:discord_history",
      "type": "Tool",
      "name": "discord_history",
      "properties": {
        "description": "Returns recent exchanges, participant/channel context, and message IDs."
      }
    },
    {
      "id": "tool:discord_reset",
      "type": "Tool",
      "name": "discord_reset",
      "properties": {
        "description": "Clears the active memory session."
      }
    },
    {
      "id": "tool:discord_restart",
      "type": "Tool",
      "name": "discord_restart",
      "properties": {
        "description": "Restarts the daemon after configuration or runtime issues."
      }
    },
    {
      "id": "actor:yamato",
      "type": "Actor",
      "name": "Yamato",
