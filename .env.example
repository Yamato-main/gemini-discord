# ── Required ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_primary_channel_id
DISCORD_OWNER_IDS=your_user_id
# When multiple owners exist, set the primary "Admin" explicitly.
DISCORD_BOSS_ID=

# ── Channel Allowlist ─────────────────────────────────────────────
# Every channel the bot or MCP tools may post to.
# Must include DISCORD_CHANNEL_ID.
ALLOWED_CHANNEL_IDS=your_primary_channel_id

# ── Speaker Allowlists ────────────────────────────────────────────
# Leave DISCORD_ALLOWED_USER_IDS blank to fall back to DISCORD_OWNER_IDS.
# Add peer bot IDs to DISCORD_ALLOWED_AGENT_IDS if you want safe bot-to-bot conversations.
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_AGENT_IDS=

# ── Internal (auto-generated by setup) ────────────────────────────
DAEMON_API_TOKEN=

# ── Optional (safe defaults shown) ───────────────────────────────
DISCORD_PREFIX=
DISCORD_RESET_CMD=!reset
DAEMON_PORT=18790
GEMINI_PATH=gemini
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Gemini Backend ───────────────────────────────────────────────
# GEMINI_BACKEND: 'cli' (Gemini CLI parity, recommended) or 'api' (direct SDK).
# Defaults to 'cli' unless explicitly set to 'api'.
GEMINI_BACKEND=
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: custom API base URL (for proxy or staging)
GEMINI_API_BASE_URL=

GEMINI_TIMEOUT_MS=300000
GEMINI_MAX_CONCURRENT=3
CONVERSATION_HISTORY_LENGTH=30
# Cap how much stored history is replayed into Gemini on each turn.
# This keeps Discord replies fast even if long-lived memory is retained on disk.
PROMPT_HISTORY_MAX_MESSAGES=12
PROMPT_HISTORY_MAX_CHARS=6000
STREAMING=true
QUEUE_MAX_DEPTH=20
ENABLE_DMS=true
REQUIRE_MENTION=false
RESPOND_TO_REPLIES=true
MEMORY_SCOPE=channel
AUTO_START_DAEMON=true
USE_GEMINI_CLI_SESSIONS=true
GEMINI_SESSION_BINDING_SCOPE=channel
CLI_IDLE_TIMEOUT_MS=300000

# ── Autonomous Away-Mode Turns ───────────────────────────────────
# Runs a separate background watcher that can wake Gemini while Yamato is away.
# This does NOT use normal Discord conversation memory and uses its own Gemini binding.
AUTONOMOUS_TURNS_ENABLED=false
AUTONOMOUS_INTERVAL_MS=300000
AUTONOMOUS_ASSUME_MASTER_AWAY=true
# Defaults to DISCORD_REPORTING_CHANNEL_ID when blank.
AUTONOMOUS_TARGET_CHANNEL_ID=
AUTONOMOUS_TARGET_CHANNEL_NAME=

# 4chan /a/ source (initial built-in collector)
AUTONOMOUS_4CHAN_A_ENABLED=false
AUTONOMOUS_4CHAN_A_BOARD=a
# Comma-separated keywords. Start with your real topic, e.g. "one piece,onepiece".
AUTONOMOUS_4CHAN_A_KEYWORDS=one piece,onepiece
AUTONOMOUS_4CHAN_A_MIN_SIGNAL=3
AUTONOMOUS_4CHAN_A_COOLDOWN_MS=3600000
AUTONOMOUS_4CHAN_A_SIGNAL_WINDOW_MS=1800000
AUTONOMOUS_4CHAN_A_TIMELINE_LIMIT=200
