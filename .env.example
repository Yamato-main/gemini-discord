# Local development example.
# End users are prompted for extension settings during `gemini extensions install`.
# The project auto-creates and manages `.gemini-discord/config.json` as the
# centralized runtime settings file. Runtime state under `.gemini-discord/`
# is already gitignored.

# ── Required ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
# Optional at first run: the daemon can remember the first owner channel.
DISCORD_CHANNEL_ID=
# Optional at first run: the daemon can infer the Discord application owner.
DISCORD_OWNER_IDS=
# When multiple owners exist, set the primary operator explicitly.
DISCORD_ADMIN_ID=

# ── Channel Allowlist ─────────────────────────────────────────────
# Every channel the bridge or MCP tools may post to.
# Leave blank to allow only DISCORD_CHANNEL_ID.
DISCORD_ALLOWED_CHANNEL_IDS=

# ── Speaker Allowlists ────────────────────────────────────────────
# Leave DISCORD_ALLOWED_USER_IDS blank to fall back to DISCORD_OWNER_IDS.
# Add peer bot IDs to DISCORD_ALLOWED_AGENT_IDS if you want safe bot-to-bot conversations.
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_AGENT_IDS=

# ── Internal (auto-generated at first run when blank) ─────────────
DAEMON_API_TOKEN=

# ── Optional (safe defaults shown) ───────────────────────────────
DISCORD_PREFIX=
DISCORD_RESET_CMD=!reset
DAEMON_PORT=18790
GEMINI_PATH=gemini
GEMINI_MODEL=gemini-3.1-flash-lite-preview

GEMINI_TIMEOUT_MS=300000
GEMINI_MAX_CONCURRENT=3
CONVERSATION_HISTORY_LENGTH=30
# Cap how much stored history is replayed into Gemini on each turn.
# This keeps Discord replies fast even if long-lived memory is retained on disk.
PROMPT_HISTORY_MAX_MESSAGES=12
PROMPT_HISTORY_MAX_CHARS=6000
STREAMING=true
QUEUE_MAX_DEPTH=20
ENABLE_DMS=true
REQUIRE_MENTION=false
RESPOND_TO_REPLIES=true
MEMORY_SCOPE=global
AUTO_START_DAEMON=true
USE_GEMINI_CLI_SESSIONS=true
GEMINI_SESSION_BINDING_SCOPE=global
CLI_IDLE_TIMEOUT_MS=300000
