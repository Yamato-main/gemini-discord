# Local development environment example.
# Run `npm run setup` to automatically generate .gemini-discord/config.json.

# ── REQUIRED ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
# Boss Discord User ID: Stable numeric Discord user ID for full bridge authority.
DISCORD_BOSS_USER_ID=000000000000000000
# Owner IDs: Legacy/setup routing list. Does not grant Boss authority.
DISCORD_OWNER_IDS=your_discord_user_id_here
DISCORD_SERVER_ID=your_discord_server_id_here

# ── OPTIONAL TARGETS ──────────────────────────────────────────────
# Primary channel for the daemon to send its initial "Online" notification.
DISCORD_CHANNEL_ID=
DISCORD_ADMIN_ID=

# ── ALLOWLISTS ────────────────────────────────────────────────────
# Allowed Channels: Leave blank to allow all channels in DISCORD_SERVER_ID.
DISCORD_ALLOWED_CHANNEL_IDS=
# Allowed Users: Leave blank to fall back to DISCORD_OWNER_IDS.
DISCORD_ALLOWED_USER_IDS=
# Peer Bot Allowlist: Add IDs of other bots allowed to trigger this agent.
DISCORD_ALLOWED_AGENT_IDS=

# ── INTERNAL (Auto-generated) ─────────────────────────────────────
DAEMON_API_TOKEN=

# ── ENGINE DEFAULTS ───────────────────────────────────────────────
DAEMON_PORT=18790
GEMINI_PATH=gemini
GEMINI_MODEL=gemini-3.1-flash-lite-preview

GEMINI_TIMEOUT_MS=300000
GEMINI_MAX_CONCURRENT=3
CONVERSATION_HISTORY_LENGTH=30
PROMPT_HISTORY_MAX_MESSAGES=12
PROMPT_HISTORY_MAX_CHARS=6000
STREAMING=true
QUEUE_MAX_DEPTH=20
ENABLE_DMS=true
REQUIRE_MENTION=false
RESPOND_TO_REPLIES=true
MEMORY_SCOPE=channel
AUTO_START_DAEMON=true
USE_GEMINI_CLI_SESSIONS=true
GEMINI_SESSION_BINDING_SCOPE=channel
CLI_IDLE_TIMEOUT_MS=300000
