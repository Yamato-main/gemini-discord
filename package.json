{
  "name": "gemini-discord",
  "version": "0.1.0",
  "type": "module",
  "description": "Always-on Discord gateway for Gemini CLI. Bidirectional chat, conversation memory, streaming responses.",
  "files": [
    "dist",
    "gemini-extension.json",
    "GEMINI.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gemini",
    "discord",
    "bot",
    "mcp",
    "ai",
    "cli"
  ],
  "author": "Author",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev:daemon": "npx tsx watch --ignore 'daemon.log' --ignore '*.sqlite*' --ignore '.env' src/daemon.ts",
    "start:daemon": "node dist/daemon.cjs",
    "start:server": "node dist/server.cjs",
    "install-service": "node dist/install-service.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
